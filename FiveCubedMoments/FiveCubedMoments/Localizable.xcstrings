    "When on, chip labels use an online service for better summaries. When off, labels use on-device processing only." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When on, chip labels use an online service for better summaries. When off, labels use on-device processing only."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "开启时，标签使用在线服务以提供更好的摘要。关闭时，仅使用本地处理。"
          }
        }
      }
    },
    "When on, long-pressing a chip shows a confirmation before deleting. When off, long-press deletes immediately." : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When on, long-pressing a chip shows a confirmation before deleting. When off, long-press deletes immediately."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "开启时，长按标签会先确认再删除。关闭时，长按直接删除。"
          }
        }
      }
    },
