    "AppTour.insights.intro": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open the Past tab for this week’s digest: days you wrote, patterns across your lines in each section, one observation grounded in what you wrote, and a practical next step. The more specific you write each day, the closer these insights stay to you. It may take a little time."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开「过去」可以查看本周摘要。每天写得越具体，这些洞察就越贴近你，不过这可能需要一点时间。"
          }
        }
      }
    },
