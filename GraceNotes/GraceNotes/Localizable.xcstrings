          "stringUnit": {
            "state": "translated",
            "value": "%1$@，%2$@，%3$lld"
          }
        }
      }
    },
    "journal.share.lineCountsFour": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@, %2$@, %3$lld, %4$lld"
          }
