          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "再记一件需要的事"
          }
        }
      }
    },
    "journal.actions.addAnotherPerson": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add another person"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "再记一位牵挂的人"
          }
        }
      }
    },
    "journal.actions.addGratitude": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add gratitude"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记一件感恩的事"
          }
        }
      }
    },
    "journal.actions.addNeed": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add need"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记一件需要的事"
          }
        }
      }
    },
    "journal.guidance.moveToSprout": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add one line in each section to move into Sprout."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "现在还什么都没有。随便开始写一些，就会进入「初露新芽」。"
          }
        }
      }
    },
    "journal.guidance.addOneMoreLineAnySection": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add one more line in any section. Small steps are easier to keep. Tap the status above anytime if you want a reminder."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在任一部分多写几条，小步最容易坚持。"
          }
        }
      }
    },
    "journal.actions.addPerson": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add person"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记一位牵挂的人"
          }
        }
      }
    },
    "journal.guidance.allSectionsThreeTowardBloom": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All sections are at three lines. Reach five lines in each section to enter Bloom."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "三个部分都已经写了三条了。继续把每个部分写到五条，就会进入「花开有成」。"
          }
        }
      }
    },
    "journal.guidance.allSectionsCompleteToday": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All sections reached five lines. Today's entry is complete."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "三个部分都写到五条了。今天这篇记录已经完整了。"
          }
        }
      }
    },
    "notifications.reminder.confirmTimeInSettings": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow notifications in Settings to confirm a reminder time."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在设置中允许通知，以确认提醒时间。"
          }
        }
      }
    },
    "notifications.reminder.enableInSettings": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow notifications in Settings to enable daily reminders."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在设置中允许通知，以启用每日提醒。"
          }
        }
      }
    },
    "startup.status.almostReady": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Almost ready. Finishing setup…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快好了，正在准备你的感恩记……"
          }
        }
      }
    },
    "journal.guidance.towardLeaf": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "At least one section has three lines. Reach three in all sections to enter Leaf."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "至少有一个部分已经写到三条了。等三个部分都写上三条以后，就会进入「叶茂成形」。"
          }
        }
      }
    },
    "journal.growthStage.balanced": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Leaf"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "叶茂成形"
          }
        }
      }
    },
    "onboarding.beginToday": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Begin today's entry"
