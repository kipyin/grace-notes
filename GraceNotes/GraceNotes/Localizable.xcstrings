    "tutorial.appTour.path.criterion.growing": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "At least one section has reached three, and at least one section is still under three."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "至少有一个部分已经达到三条，也至少有一个部分还不到三条。"
          }
        }
      }
    },
    "tutorial.appTour.path.criterion.started": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "At least one strip is filled, and all three sections are still under three."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你已经写下至少一条，而且三个部分都还不到三条。"
          }
        }
      }
    },
    "tutorial.appTour.path.intro": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A small seed can grow with what you write today. Try adding a little more whenever you're ready."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一颗小小的种子会随着你今天写下的内容慢慢长大。准备好了，就多写一点。"
          }
        }
      }
    },
    "tutorial.appTour.reminders.intro": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "It’s easy to forget gratitude. Turn on a daily reminder to keep your Grace Notes habit."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们经常会忘记表达感恩。可以打开每日提醒来记录当天的感恩记。"
          }
        }
      }
    },
