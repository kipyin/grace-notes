    "accessibility.list.itemPosition": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ item %2$d of %3$d"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@，第 %2$d 项，共 %3$d 项"
          }
