    "tutorial.appTour.icloud.intro": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After you sign in to iCloud, Grace Notes can sync across your devices."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "登录 iCloud 后，感恩记可在你的设备间同步。"
          }
        }
      }
    },
    "tutorial.appTour.insights.intro": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open the Past tab for this week’s digest: days you wrote, patterns across your lines in each section, one observation grounded in what you wrote, and a practical next step. The more specific you write each day, the closer these insights stay to you. It may take a little time."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开「过去」可以查看本周摘要。每天写得越具体，这些洞察就越贴近你，不过这可能需要一点时间。"
          }
        }
      }
    },
    "tutorial.appTour.pageIndicator": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Page %1$lld of %2$lld"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "第 %1$lld 页，共 %2$lld 页"
          }
        }
      }
    },
