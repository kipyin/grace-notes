            "state": "translated",
            "value": "%2$d 条中的第 %1$d 条"
          }
        }
      }
    },
    "sharing.numberedLine": {
      "comment": "Generic numbered line for share cards and similar lists. %1$lld is the line number; %2$@ is the line text.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld. %2$@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld、%2$@"
          }
        }
      }
    },
    "review.prompts.nextStep": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A next step"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下一步"
          }
        }
      }
    },
    "journal.actions.addAnotherGratitude": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add another gratitude"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "再记一件感恩的事"
