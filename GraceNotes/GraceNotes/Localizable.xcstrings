      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ input"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 输入"
          }
        }
      }
    },
    "accessibility.sectionUpdating": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ section is updating."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "正在更新 %@。"
