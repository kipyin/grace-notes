    },
    "journal.share.sectionCountsSentence": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@. Gratitudes: %2$d. Needs: %3$d. People in Mind: %4$d."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@。感恩的事 %2$d 条。需要的事 %3$d 条。牵挂的人 %4$d 条。"
          }
        }
      }
    },
    "review.history.weekComparisonArrow": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld → %2$lld"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$lld → %2$lld"
