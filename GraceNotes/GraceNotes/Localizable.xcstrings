      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All five spots are filled in Gratitudes, Needs, and People in Mind."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "感恩的事、需要的事和牵挂的人都已写满五条。"
