      }
    },
    "journal.section.progressSummary": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@ progress. %2$d complete, %3$d in progress, %4$d open."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@：已完成 %2$d 项，进行中 %3$d 项，未开始 %4$d 项。"
          }
        }
      }
    },
    "journal.share.lineCountsThree": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@, %2$@, %3$lld"
          }
        },
