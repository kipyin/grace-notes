    "settings.dataPrivacy.a11y.storage": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Grace Notes data storage"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "感恩记数据存储"
          }
        }
      }
    },
    "settings.dataPrivacy.a11y.storage.cloudActive": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Storage: Grace Notes syncs to iCloud from this device."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "存储：感恩记正通过此设备同步到 iCloud。"
          }
        }
      }
    },
    "settings.dataPrivacy.attention.noAccount.summary": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This device isn’t signed in to iCloud, so sync can’t start yet. Sign in from Settings, or open Settings below."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备尚未登录 iCloud，暂时还不能开启同步。请到「设置」登录，或轻点下方的「打开设置」。"
          }
        }
      }
    },
    "settings.dataPrivacy.attention.preferenceMismatchRelaunch.summary": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your sync setting doesn’t match how data is stored on this device right now."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前同步设置和本机正在使用的存储方式不一致。"
          }
        }
      }
    },
    "settings.dataPrivacy.attention.restricted.summary": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud is restricted on this device."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此设备上的 iCloud 目前受到限制。"
          }
        }
      }
    },
    "settings.dataPrivacy.attention.retryICloudAfterRelaunch.summary": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quit Grace Notes once and open it again to try connecting to iCloud."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先关掉感恩记再打开，试试能否连上 iCloud。"
          }
        }
      }
    },
    "settings.dataPrivacy.attention.tempUnavailable": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud isn't available right now. Your entries still save on this device."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂时用不了 iCloud，记录照常保存在本设备。"
          }
        }
      }
    },
    "settings.dataPrivacy.attention.tempUnavailableMismatch.summary": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud is temporarily unavailable. Your entries still save on this device."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂时连不上 iCloud，记录仍保存在本设备。"
          }
        }
      }
    },
    "settings.dataPrivacy.attention.toggleChangedRelaunch.summary": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Restart Grace Notes to apply your iCloud sync change."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "改了 iCloud 同步后，需要重新打开感恩记才会生效。"
          }
        }
      }
    },
    "settings.dataPrivacy.attention.unknown": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't verify iCloud status. Your entries still save on this device."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 状态暂时未知，记录仍保存在本设备。"
          }
        }
      }
    },
    "settings.dataPrivacy.attention.unknownMismatch.summary": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn’t verify iCloud status. Your entries still save on this device."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 状态暂时未知，记录仍保存在本设备。"
          }
        }
      }
    },
    "settings.dataPrivacy.import.action": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Import"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导入"
          }
        }
      }
    },
    "settings.dataPrivacy.import.error.fileTooLarge": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This file is too large to import. Try a smaller Grace Notes backup."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这份文件太大，无法导入。请换一个小一些的感恩记备份。"
          }
        }
      }
    },
    "settings.dataPrivacy.import.error.generic": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to import your data right now. Please try again."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂时无法导入数据，请稍后再试。"
          }
        }
      }
    },
    "settings.dataPrivacy.import.error.invalid": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This file doesn’t look like a Grace Notes export."
          }
